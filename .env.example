# Copie este arquivo para .env e preencha com seus valores locais
# cp .env.example .env

# Usuário dentro do container (padrão: jovyan)
NB_USER=hexdata
NB_UID=1000
NB_GID=100

# Porta local do Jupyter (padrão: 8888)
JUPYTER_PORT=8888

# Caminho absoluto da pasta de trabalho no host
# Ajuste conforme seu sistema operacional:
#
#   WSL 2 (Windows):        /mnt/c/projeto
#   Linux nativo (Ubuntu):  /home/seuUsuario/projeto
#   macOS:                  /Users/seuUsuario/projeto
#   Docker Toolbox (legado):/c/Users/seuUsuario/projeto
#
WORK_DIR=/mnt/c/projeto
