*.egg-info/
dist/
build/
.eggs/

# Arquivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# Claude Code (arquivos internos do assistente)
.claude/

# Editores
.vscode/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Dados sensíveis ou volumosos
*.csv
*.parquet
*.xlsx
*.xls
data/
datasets/
*.rar
